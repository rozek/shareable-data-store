{
  "name": "shareable-notes-store",
  "description": "A CRDT-based, offline-capable, syncable tree of notes for Browser and Node.js",
  "keywords": [
    "crdt",
    "notes",
    "collaborative",
    "offline-first",
    "sync",
    "json-joy",
    "websocket",
    "webrtc",
    "indexeddb"
  ],
  "author": "Andreas Rozek",
  "homepage": "https://github.com/rozek/shareable-notes-store#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rozek/shareable-notes-store.git"
  },
  "bugs": {
    "url": "https://github.com/rozek/shareable-notes-store/issues"
  },
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build":     "pnpm -r build",
    "test":      "pnpm -r test:run",
    "test:run":  "pnpm -r test:run",
    "dev":       "pnpm -r dev",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "version":   "changeset version",
    "release":   "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "typescript":      "^5.7.2"
  }
}
