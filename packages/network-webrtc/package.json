{
  "name": "@rozek/sns-network-webrtc",
  "description": "WebRTC sync + presence provider for shareable-notes-store (browser)",
  "version": "0.0.1",
  "author": "Andreas Rozek",
  "homepage": "https://github.com/rozek/shareable-notes-store#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rozek/shareable-notes-store.git",
    "directory": "packages/network-webrtc"
  },
  "bugs": { "url": "https://github.com/rozek/shareable-notes-store/issues" },
  "license": "MIT",
  "type": "module",
  "main":   "./dist/sns-network-webrtc.js",
  "module": "./dist/sns-network-webrtc.js",
  "types":  "./dist/sns-network-webrtc.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sns-network-webrtc.js",
      "types":  "./dist/sns-network-webrtc.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev":       "vite build --watch",
    "build":     "vite build",
    "test":      "vitest",
    "test:run":  "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@rozek/sns-core":              "workspace:*",
    "@rozek/sns-network-websocket": "workspace:*"
  },
  "devDependencies": {
    "@rozek/sns-core":              "workspace:*",
    "@rozek/sns-network-websocket": "workspace:*",
    "typescript":                   "^5.7.2",
    "vite":                         "^6.0.0",
    "vite-plugin-dts":              "^4.0.0",
    "vitest":                       "^2.0.0"
  }
}
