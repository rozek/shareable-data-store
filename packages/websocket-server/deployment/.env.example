# /opt/sds-websocket-server/.env
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# required: at least 32 random characters of entropy
# generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SDS_JWT_SECRET=<insert_strong_secret_here>

# optional: validated as the "iss" claim in JWTs
# SDS_ISSUER=https://notes.example.com

# internal: the server binds to all interfaces inside the container
SDS_HOST=0.0.0.0
SDS_PORT=3000

# optional: enable SQLite persistence (directory inside the container)
# remove or leave empty for pure relay mode (no server-side storage)
SDS_PERSIST_DIR=/data/stores

# subdomain for the SDS server (used by Caddy for TLS)
# to run additional services on other subdomains, add their domains to the
# Caddyfile and define the corresponding services in docker-compose.yml
SDS_DOMAIN=notes.example.com

# E-mail address for Let's Encrypt notifications (shared across all subdomains)
ACME_EMAIL=admin@example.com
