{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "paths": {
      "@rozek/sds-core-loro":           ["../core-loro/src/sds-core-loro.ts"],
      "@rozek/sds-core":                ["../core/src/sds-core.ts"],
      "@rozek/sds-network-websocket":   ["../network-websocket/src/sds-network-websocket.ts"],
      "@rozek/sds-network-webrtc":      ["../network-webrtc/src/sds-network-webrtc.ts"],
      "@rozek/sds-persistence-browser": ["../persistence-browser/src/sds-persistence-browser.ts"],
      "@rozek/sds-sync-engine":         ["../sync-engine/src/sds-sync-engine.ts"]
    }
  },
  "include": [
    "src",
    "../core/src",
    "../core-loro/src",
    "../network-websocket/src",
    "../network-webrtc/src",
    "../persistence-browser/src",
    "../sync-engine/src"
